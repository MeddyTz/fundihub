# Selcom credentials from Selcom. Keep these server-side only.
SELCOM_BASE_URL=https://apigw.selcommobile.com
SELCOM_API_KEY=replace_with_api_key
SELCOM_API_SECRET=replace_with_api_secret
SELCOM_VENDOR=replace_with_vendor_id

# Public URLs after deployment
FUNDIHUB_FUNCTIONS_BASE_URL=https://YOUR_REGION-YOUR_PROJECT.cloudfunctions.net/api
FUNDIHUB_PAYMENT_REDIRECT_URL=https://fundihub.app/payment-result
FUNDIHUB_PAYMENT_CANCEL_URL=https://fundihub.app/payment-cancelled

# Webhook security token you give Selcom for callbacks, if using token validation.
SELCOM_WEBHOOK_TOKEN=replace_with_long_random_token
